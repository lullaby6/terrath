{
  "name": "terrath",
  "description": "",
  "version": "0.0.0",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "node log.js dev & vite --config vite/config.dev.mjs",
    "build": "node log.js build & vite build --config vite/config.prod.mjs",
    "dev-nolog": "vite --config vite/config.dev.mjs",
    "build-nolog": "vite build --config vite/config.prod.mjs",
    "electron:dev": "electron .",
    "electron:build": "vite build --config vite/config.prod.mjs && electron-builder"
  },
  "build": {
    "appId": "com.terrath.game",
    "productName": "terrath",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "extraResources": [
      {
        "from": "mods",
        "to": "../mods"
      }
    ],
    "win": {
      "target": "dir"
    },
    "asar": true
  },
  "devDependencies": {
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "sucrase": "^3.35.1",
    "typescript": "~5.7.2",
    "vite": "^6.3.1",
    "vite-tsconfig-paths": "^6.1.1"
  },
  "dependencies": {
    "phaser": "4.0.0",
    "terser": "^5.39.0"
  }
}
